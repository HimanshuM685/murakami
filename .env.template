NODE_ENV=development

# Transit engine path values for the different roles
VAULT_TRANSIT_USERS_PATH=pawn/users
VAULT_TRANSIT_MANAGERS_PATH=pawn/managers

# Default vault user
VAULT_MANAGER_KEY=manager

# Usually docker network domain
# Change if you are using a different network or want to connect to a remote vault
VAULT_BASE_URL=http://vault:8200
VAULT_LOCAL_URL=http://localhost:8200
VAULT_NAMESPACE=

# DEFAULT ROLE ID and SECRET ID for the user to access the vault
# REPLACE WITH YOUR OWN VALUES
VAULT_ROLE_ID=someRoleID
VAULT_SECRET_ID=someUserId

# Uses local instance of vault
CLI_USE_LOCAL_VAULT=true

# ─── Algorand network selection ───────────────────────────────────────────
# Pick ONE network below. GENESIS_ID/GENESIS_HASH are baked into every
# transaction and also drive the did:algo:<network> slug, so they MUST match
# the node NODE_HOST points at — otherwise the network rejects your txns.

# TestNet (public AlgoNode endpoint, no token required)
GENESIS_ID=testnet-v1.0
GENESIS_HASH=SGO1GKSzyE7IEPItTxCByw9x8FmnrCDexi9/cOUJOiI=
NODE_HTTP_SCHEME=https
NODE_HOST=testnet-api.algonode.cloud
NODE_PORT=443
NODE_TOKEN=

# MainNet (public AlgoNode endpoint, no token required)
# GENESIS_ID=mainnet-v1.0
# GENESIS_HASH=wGHE2Pwdvd7S12BL5FaOP20EGYesN73ktiC1qzkkit8=
# NODE_HTTP_SCHEME=https
# NODE_HOST=mainnet-api.algonode.cloud
# NODE_PORT=443
# NODE_TOKEN=

# LocalNet (algokit sandbox) — requires `algokit localnet start`.
# Inside the pawn container reach the sandbox via host `algod` port `8080`.
# GENESIS_ID=dockernet-v1
# GENESIS_HASH=MU03J7aP42QIzRUjiNuSKPPxyv108uGZlA3nFFtC3fk=
# NODE_HTTP_SCHEME=http
# NODE_HOST=localhost
# NODE_PORT=4001
# NODE_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

JWT_SECRET='DO NOT USE THIS VALUE'